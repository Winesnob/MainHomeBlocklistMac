||cloudflare-dns.com^
||mozilla.cloudflare-dns.com^
||dns.quad9.net^
||nextdns.io^
||security.cloudflare-dns.com^
||doh.opendns.com^
||dns.adguard.com^
||dns.familyshield.opendns.com^
